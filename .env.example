# ============================================
# PDF 知识库问答系统 - 环境变量配置
# ============================================
# 将本文件复制为 .env 并填入你的配置：
#   cp .env.example .env
# ============================================

# ---- 必填 ----
# DeepSeek API Key (从 https://platform.deepseek.com 获取)
DEEPSEEK_API_KEY=your_api_key_here

# ---- 可选（有默认值） ----
# API 地址（如使用第三方代理，请修改这里）
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# 模型名称
DEEPSEEK_MODEL=deepseek-chat

# 单次最大输出 token 数
LLM_MAX_TOKENS=4096
